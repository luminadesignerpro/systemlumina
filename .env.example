# =====================================
# SUPABASE CONFIGURATION
# =====================================
# Obtenha estas credenciais em: https://app.supabase.com/project/_/settings/api

# URL do projeto Supabase (ex: https://xxxxx.supabase.co)
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# Chave pública/anon do Supabase (seguro para o frontend)
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"

# ID do projeto Supabase (ex: xxxxx)
VITE_SUPABASE_PROJECT_ID="seu-project-id"

# =====================================
# META BUSINESS API (WhatsApp + Instagram)
# =====================================
# Obtenha em: https://developers.facebook.com/apps

# App ID do Meta (encontrado em Settings > Basic)
# Usado nas Edge Functions do Supabase
META_APP_ID="seu-meta-app-id"

# App Secret do Meta (encontrado em Settings > Basic)
# ⚠️ NUNCA exponha no frontend!
META_APP_SECRET="seu-meta-app-secret"

# =====================================
# WHATSAPP BUSINESS API
# =====================================

# Token de verificação do webhook (pode ser qualquer string)
# Use o mesmo valor ao configurar o webhook no Meta
WHATSAPP_WEBHOOK_VERIFY_TOKEN="systemlumina_verify_token_2026"

# =====================================
# OPENAI (Opcional - para geração de conteúdo com IA)
# =====================================
# Obtenha em: https://platform.openai.com/api-keys

# Chave da API OpenAI (começa com sk-)
# Usado para gerar conteúdo de posts automaticamente
OPENAI_API_KEY="sk-sua-chave-aqui"

# =====================================
# NOTAS IMPORTANTES
# =====================================
#
# 1. NUNCA commite o arquivo .env no Git (já está no .gitignore)
# 2. Para produção (Vercel), configure estas variáveis no dashboard
# 3. Para Supabase Edge Functions, use: supabase secrets set KEY=value
# 4. Tokens devem ser regenerados periodicamente (a cada 90 dias)
# 5. Mantenha backups seguros das credenciais
#
# =====================================

